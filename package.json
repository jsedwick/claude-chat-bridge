{
  "name": "claude-chat-bridge",
  "version": "1.0.0",
  "description": "Web chat interface for Claude Code with MCP tools, accessible over Tailscale",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null || true",
    "start": "node dist/server.js",
    "dev": "tsc && node dist/server.js",
    "start:http": "node dist/server.js --http"
  },
  "author": "Jesse Sedwick",
  "license": "MIT",
  "dependencies": {
    "@types/ws": "^8.18.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "node-pty": "^1.1.0",
    "web-push": "^3.6.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.10.0",
    "@types/web-push": "^3.6.4",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
